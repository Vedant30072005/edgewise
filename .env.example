# Edgewise — environment configuration template.
# LOCAL: copy to .env and fill in. DEPLOYMENT: set these as environment variables
# on your host (Render/Railway/Fly dashboard, or docker --env-file).
# See the "Deploying" section in README.md.

# Server
PORT=3000
# Use 'production' on your host (the Dockerfile sets this for you). Production
# enables Secure cookies, HSTS, and HTTP→HTTPS redirects. Use 'development' locally.
NODE_ENV=development

# Auth — REQUIRED. Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Admin account (seeded into a fresh database on first run only).
ADMIN_EMAIL=admin@edgewise.local
ADMIN_PASSWORD=change-me-to-a-strong-password

# AI-powered weekly debrief (optional — falls back to algorithmic if not set)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Public URL of this app (used in email links). On the host, set your https domain.
APP_URL=http://localhost:3000

# SQLite location. Empty = ./data (local). On a host, point this at a mounted
# persistent volume (e.g. /data) so the database survives restarts/deploys.
DATA_DIR=

# Email / SMTP (optional — dev mode prints links to console instead)
# Works with any SMTP provider (Gmail, Resend, Postmark, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Edgewise <noreply@yourdomain.com>
